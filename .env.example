# Backend API base used by server components/proxy.
# Optional: defaults to http://127.0.0.1:8000/api/v1 when unset.
BDMS_API_URL=http://127.0.0.1:8000/api/v1

# Supabase auth settings (required)
SUPABASE_PROJECT_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# Optional aliases used by runtime fallback logic
# NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_URL=https://your-project-ref.supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
# SUPABASE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
